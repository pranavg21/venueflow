# ─── Firebase Client Config (obtain from Firebase Console → Project Settings → Web App) ───
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# ─── Google Maps (obtain from Google Cloud Console → APIs & Services → Credentials) ───
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── Firebase Admin (Server-side) ───
# Base64-encoded Firebase service account JSON (obtain from Firebase Console → Project Settings → Service Accounts → Generate New Private Key)
FIREBASE_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# ─── Gemini API (obtain from Google AI Studio → https://aistudio.google.com/apikey) ───
GEMINI_API_KEY=your-gemini-api-key

# ─── Server Config ───
PORT=8080
NODE_ENV=production
CORS_ORIGIN=http://localhost:5173
